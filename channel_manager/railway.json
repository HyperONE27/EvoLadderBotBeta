{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "Railpack"
    },
    "deploy": {
        "startCommand": "uv run uvicorn channel_manager.app:app --host 0.0.0.0 --port 8090",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}