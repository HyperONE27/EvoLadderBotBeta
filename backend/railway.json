{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "Railpack"
    },
    "deploy": {
        "startCommand": "uvicorn backend.api.app:app --host 0.0.0.0 --port 8080 --workers 1",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}