# -------
# Backend
# -------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=

# Optional: URL of the channel manager service. If unset, channel creation is skipped.
# CHANNEL_MANAGER_URL=

# Optional: number of ProcessPoolExecutor workers for replay parsing (default: 2).
# REPLAY_WORKER_PROCESSES=2

# ---
# Bot
# ---
BOT_TOKEN=
BACKEND_URL=
MATCH_LOG_CHANNEL_ID=

# Optional: public HTTPS URL for the footer icon on branded embeds.
# BOT_ICON_URL=

# ---------------
# Channel Manager
# ---------------
CHANNEL_MANAGER_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_CATEGORY_ID=

# Optional: comma-separated role IDs granted access to match channels.
# DISCORD_STAFF_ROLE_IDS=

# Optional: seconds to wait before deleting a channel after a match ends (default: 0).
# CHANNEL_DELETION_DELAY_SECONDS=0
